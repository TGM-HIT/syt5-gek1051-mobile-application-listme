<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug: trust everything — self-signed certs, HTTP, local IPs -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />  <!-- trust manually installed certs -->
        </trust-anchors>
    </base-config>
</network-security-config>
